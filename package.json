{
  "name": "ghscope",
  "version": "0.1.0",
  "description": "CLI that tells you everything about a GitHub org before you contribute or apply",
  "type": "module",
  "bin": {
    "ghscope": "bin/stackprobe.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "keywords": [
    "github",
    "cli",
    "org",
    "contributor",
    "devtools"
  ],
  "license": "MIT",
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
